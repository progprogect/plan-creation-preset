{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preset.local/schemas/layout_draft.json",
  "title": "LayoutDraft",
  "type": "object",
  "required": ["version", "units", "rooms"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1]
    },
    "units": {
      "type": "string",
      "enum": ["mm", "cm", "m"]
    },
    "title": { "type": "string" },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "polygon"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "zone_type": {
            "type": "string",
            "enum": ["production", "storage", "other"]
          },
          "polygon": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          }
        }
      }
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "bbox", "text_description"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type_tag": { "type": "string", "description": "Условный тип узла для промпта" },
          "z_index": { "type": "number" },
          "bbox": {
            "type": "object",
            "required": ["x", "y", "width", "height"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number", "minimum": 0 },
              "height": { "type": "number", "minimum": 0 },
              "rotation": { "type": "number" }
            }
          },
          "text_description": {
            "type": "string",
            "description": "Краткое описание для генерации пиктограммы (вид сверху, узел)"
          }
        }
      }
    },
    "annotations": {
      "type": "object",
      "additionalProperties": true
    },
    "layout_notes": {
      "type": "string",
      "description": "Свободные заметки LLM; не используются рендером напрямую"
    }
  }
}
