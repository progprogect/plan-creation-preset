{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preset.local/schemas/floorplan_spec.json",
  "title": "FloorplanSpec",
  "type": "object",
  "required": ["version", "units", "rooms"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1, 2]
    },
    "units": {
      "type": "string",
      "enum": ["mm", "cm", "m"]
    },
    "title": { "type": "string", "default": "Floor plan" },
    "metadata": { "type": "object", "additionalProperties": true },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "polygon"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "zone_type": {
            "type": "string",
            "enum": ["production", "storage", "other"]
          },
          "polygon": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          }
        }
      }
    },
    "walls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x1", "y1", "x2", "y2"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "x1": { "type": "number" },
          "y1": { "type": "number" },
          "x2": { "type": "number" },
          "y2": { "type": "number" },
          "thickness": { "type": "number", "minimum": 0 }
        }
      }
    },
    "openings": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "equipment": {
      "type": "array",
      "description": "Оборудование: для version 2",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "z_index": { "type": "number" },
          "footprint_only": { "type": "boolean" },
          "bbox": {
            "type": "object",
            "required": ["x", "y", "width", "height"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number", "minimum": 0 },
              "height": { "type": "number", "minimum": 0 },
              "rotation": { "type": "number" }
            }
          },
          "polygon": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          },
          "representation": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "annotations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "callouts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "target_id": { "type": "string" },
              "anchor": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "offset": {
                "type": "object",
                "properties": {
                  "dx": { "type": "number" },
                  "dy": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "render_profile": {
          "type": "string",
          "enum": ["schematic", "technical_bw"]
        },
        "wall_stroke_mm": { "type": "number" },
        "grid_step": { "type": "number" },
        "show_grid": { "type": "boolean" },
        "show_coord_grid": { "type": "boolean" },
        "room_palette": {
          "type": "array",
          "items": { "type": "string" }
        },
        "technical": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
