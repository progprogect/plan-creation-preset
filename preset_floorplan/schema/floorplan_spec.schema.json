{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preset.local/schemas/floorplan_spec.json",
  "title": "FloorplanSpec",
  "type": "object",
  "required": ["version", "units", "rooms"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "units": {
      "type": "string",
      "enum": ["mm", "cm", "m"]
    },
    "title": {
      "type": "string",
      "default": "Floor plan"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "polygon"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "polygon": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          }
        }
      }
    },
    "walls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x1", "y1", "x2", "y2"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "x1": { "type": "number" },
          "y1": { "type": "number" },
          "x2": { "type": "number" },
          "y2": { "type": "number" },
          "thickness": { "type": "number", "minimum": 0 }
        }
      }
    },
    "openings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "wall_stroke_mm": { "type": "number" },
        "grid_step": { "type": "number" },
        "show_grid": { "type": "boolean" },
        "room_palette": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
